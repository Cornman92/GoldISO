{
  "version": "2.0",
  "drives": {
    "gaming": "C",
    "apps": "F",
    "media": "H",
    "dev": "C"
  },
  "partitions": {
    "apps_size_gb": 100,
    "scratch_size_gb": 120,
    "media_size_gb": 500
  },
  "target": {
    "os_disk_type": "NVMe",
    "wipe_all_secondary": true
  },
  "identity": {
    "computer_name_prefix": "GOLD-",
    "owner_name": "Cornman92",
    "auto_start_app": true,
    "timezone": "UTC"
  },
  "optimizations": {
    "game_mode": true,
    "hags": true,
    "hpet_disabled": true,
    "telemetry_disabled": true,
    "uac_level": 2,
    "win_defender_enabled": true,
    "msi_mode_enabled": true,
    "timer_resolution_ms": 0.5
  },
  "network": {
    "dns_primary": "1.1.1.1",
    "dns_secondary": "1.0.0.1",
    "disable_ipv6": true,
    "tcp_window_scaling": true
  },
  "privacy": {
    "disable_diag_data": true,
    "disable_location": true,
    "disable_activity_history": true,
    "disable_advertising_id": true
  },
  "visuals": {
    "acrylic_enabled": true,
    "transparency_effects": true,
    "disable_startup_sound": true,
    "font_smoothing": true
  },
  "cleanup": {
    "aggressive": false,
    "clear_browser_cache": true,
    "max_age_days": 7
  }
}