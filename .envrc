#!/usr/bin/env bash
# shell: bash
# GoldISO Project Environment Configuration
# This file is automatically loaded by direnv when entering this directory
# Documentation: https://direnv.net/

# Prevent accidental loading in production systems
if [[ "$HOSTNAME" == *"prod"* ]] || [[ "$COMPUTERNAME" == *"PROD"* ]]; then
    echo "ERROR: Refusing to load .envrc in production environment"
    exit 1
fi

# Project paths
GOLDISO_ROOT=$(pwd)
export GOLDISO_ROOT
export GOLDISO_SCRIPTS="$GOLDISO_ROOT/Scripts"
export GOLDISO_CONFIG="$GOLDISO_ROOT/Config"
export GOLDISO_TESTS="$GOLDISO_ROOT/Tests"

# PowerShell module path for local modules
export PSModulePath="$GOLDISO_ROOT/Scripts/Modules:$PSModulePath"

# Add Scripts directory to PATH
export PATH="$GOLDISO_SCRIPTS:$PATH"
export PATH="$GOLDISO_SCRIPTS/Build:$PATH"
export PATH="$GOLDISO_SCRIPTS/Operations:$PATH"

# PowerShell execution policy for this project (development only)
export POWERSHELL_EXECUTIONPOLICY="RemoteSigned"

# Default parameters for build scripts
export GOLDISO_BUILD_VERBOSE="true"
export GOLDISO_BUILD_LOG="$GOLDISO_ROOT/build.log"

# Editor configuration
export EDITOR="code"

# Project-specific aliases (bash/Git Bash compatible)
alias build="pwsh -File ./Scripts/Build/CompleteBuild.ps1"
alias test-pwsh="pwsh -Command \"Invoke-Pester -Path ./Tests -Output Detailed\""
alias gold-backup="pwsh -File ./Scripts/Backup-Config.ps1"
alias gold-apply="pwsh -File ./Scripts/Apply-Image.ps1"

# Display project info
echo "GoldISO Project Environment Loaded"
echo "  Root: $GOLDISO_ROOT"
echo "  Available aliases: build, test-pwsh, gold-backup, gold-apply"
