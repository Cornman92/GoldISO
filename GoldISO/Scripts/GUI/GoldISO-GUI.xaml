<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GoldISO Control Center V2.0" Height="800" Width="1100"
        Background="#121212" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen" BorderThickness="1" BorderBrush="#2D2D30">
    <Window.Resources>
        <!-- Sidebar Button Style -->
        <Style TargetType="RadioButton" x:Key="SidebarButton">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" Name="Border" Padding="{TemplateBinding Padding}" 
                                BorderThickness="4,0,0,0" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#D4AF37"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#D4AF37"/>
                                <Setter Property="Background" Value="#1E1E1E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252526"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Style -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#D4AF37"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Padding" Value="15"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/> <!-- Sidebar -->
            <ColumnDefinition Width="*"/>   <!-- Content -->
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/> <!-- Terminal -->
        </Grid.RowDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Grid.RowSpan="2" Background="#181818" BorderThickness="0,0,1,0" BorderBrush="#2D2D30">
            <StackPanel Margin="0,20,0,0">
                <StackPanel Orientation="Horizontal" Margin="20,0,0,30">
                    <TextBlock Text="GOLD" Foreground="#D4AF37" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="ISO" Foreground="White" FontSize="20" FontWeight="Bold"/>
                </StackPanel>

                <RadioButton Content="Configure" Style="{StaticResource SidebarButton}" IsChecked="True" Tag="PageConfig" Name="NavConfig"/>
                <RadioButton Content="Tuning" Style="{StaticResource SidebarButton}" Tag="PageTune" Name="NavTune"/>
                <RadioButton Content="Applications" Style="{StaticResource SidebarButton}" Tag="PageApps" Name="NavApps"/>
                <RadioButton Content="Build" Style="{StaticResource SidebarButton}" Tag="PageBuild" Name="NavBuild"/>
                <RadioButton Content="Maintenance" Style="{StaticResource SidebarButton}" Tag="PageMain" Name="NavMain"/>
                <RadioButton Content="Developer" Style="{StaticResource SidebarButton}" Tag="PageDev" Name="NavDev"/>
                <RadioButton Content="Services" Style="{StaticResource SidebarButton}" Tag="PageServices" Name="NavServices"/>
                <RadioButton Content="Drivers" Style="{StaticResource SidebarButton}" Tag="PageDrivers" Name="NavDrivers"/>
                <RadioButton Content="Debloat" Style="{StaticResource SidebarButton}" Tag="PageDebloat" Name="NavDebloat"/>
                <RadioButton Content="Registry" Style="{StaticResource SidebarButton}" Tag="PageRegistry" Name="NavRegistry"/>


                
                <Separator Background="#2D2D30" Margin="20,20"/>
                
                <StackPanel Margin="20,0">
                    <TextBlock Text="STATUS" Foreground="#555555" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Name="StatusIndicator" Text="Ready" Foreground="#888888" FontSize="12"/>
                    <ProgressBar Name="GlobalProgress" Height="6" Margin="0,10,0,0" Background="#333333" Foreground="#D4AF37" BorderThickness="0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Column="1" Grid.Row="0" Margin="20">
            <!-- CONFIGURATION PAGE -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Name="PageConfig" Visibility="Visible">
                <StackPanel>
                    <TextBlock Text="System Configuration" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <GroupBox Header="Identity">
                                <StackPanel>
                                    <TextBlock Text="Computer Prefix"/>
                                    <TextBox Name="CfgCompName" Background="#252526" Foreground="White" Margin="0,5,0,10" Padding="5"/>
                                    <TextBlock Text="Owner Name"/>
                                    <TextBox Name="CfgOwner" Background="#252526" Foreground="White" Margin="0,5,0,0" Padding="5"/>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="Storage Partitions">
                                <StackPanel>
                                    <TextBlock Text="Apps (GB)"/>
                                    <DockPanel LastChildFill="True">
                                        <TextBlock Text="{Binding Value, ElementName=CfgAppsSize}" Width="30" Foreground="#D4AF37" DockPanel.Dock="Right" TextAlignment="Right"/>
                                        <Slider Name="CfgAppsSize" Minimum="20" Maximum="1000" IsSnapToTickEnabled="True" TickFrequency="10"/>
                                    </DockPanel>
                                    <TextBlock Text="Scratch (GB)" Margin="0,10,0,0"/>
                                    <DockPanel LastChildFill="True">
                                        <TextBlock Text="{Binding Value, ElementName=CfgScratchSize}" Width="30" Foreground="#D4AF37" DockPanel.Dock="Right" TextAlignment="Right"/>
                                        <Slider Name="CfgScratchSize" Minimum="20" Maximum="500" IsSnapToTickEnabled="True" TickFrequency="10"/>
                                    </DockPanel>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <GroupBox Header="Drives">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                    <TextBlock Text="Gaming" VerticalAlignment="Center" Margin="0,5"/>
                                    <ComboBox Name="CfgGamingDrive" Grid.Column="1" Width="60" HorizontalAlignment="Right" Background="#252526" Foreground="White" Margin="0,5"/>
                                    <TextBlock Text="Apps" Grid.Row="1" VerticalAlignment="Center" Margin="0,5"/>
                                    <ComboBox Name="CfgAppsDrive" Grid.Column="1" Grid.Row="1" Width="60" HorizontalAlignment="Right" Background="#252526" Foreground="White" Margin="0,5"/>
                                    <TextBlock Text="Media" Grid.Row="2" VerticalAlignment="Center" Margin="0,5"/>
                                    <ComboBox Name="CfgMediaDrive" Grid.Column="1" Grid.Row="2" Width="60" HorizontalAlignment="Right" Background="#252526" Foreground="White" Margin="0,5"/>
                                </Grid>
                            </GroupBox>
                            <GroupBox Header="Deployment Safety">
                                <StackPanel>
                                    <CheckBox Name="CfgWipeAll" Content="Protect Secondary Drives" Foreground="White" Margin="0,5"/>
                                    <CheckBox Name="CfgAutoUnmount" Content="Auto-Dismount on Error" Foreground="White" Margin="0,5"/>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </Grid>
                    <Button Name="SaveConfig" Content="SAVE CONFIGURATION" Height="40" Background="#2D2D30" Foreground="White" BorderBrush="#D4AF37"/>
                </StackPanel>
            </ScrollViewer>

            <!-- TUNING PAGE -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Name="PageTune" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="System Tuning" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    <UniformGrid Columns="2">
                        <GroupBox Header="Optimization Preferences" Foreground="#D4AF37">
                            <StackPanel>
                                <CheckBox Name="CfgAutoStartApp" Content="Auto-Start GoldISO App on Login" Foreground="White" Margin="0,5"/>
                                <CheckBox Name="CfgGameMode" Content="Enable Windows Game Mode" Foreground="White" Margin="0,5"/>
                                <CheckBox Name="CfgHAGS" Content="Enable HAGS (GPU Scheduling)" Foreground="White" Margin="0,8"/>
                                <CheckBox Name="CfgNoHPET" Content="Force-Disable HPET" Foreground="White" Margin="0,8"/>
                                <CheckBox Name="CfgMSIMode" Content="Enable MSI Mode for GPU" Foreground="White" Margin="0,8"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Network">
                            <StackPanel>
                                <TextBlock Text="Primary DNS"/>
                                <TextBox Name="CfgDnsPri" Background="#252526" Foreground="White" Margin="0,5,0,10" Padding="5"/>
                                <CheckBox Name="CfgNoIPv6" Content="Disable IPv6 Stack" Foreground="White" Margin="0,8"/>
                                <CheckBox Name="CfgTCPWin" Content="Enable TCP Window Scaling" Foreground="White" Margin="0,8"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Privacy &amp; Telemetry">
                            <StackPanel>
                                <CheckBox Name="CfgNoTelemetry" Content="Block All Telemetry" Foreground="White" Margin="0,8"/>
                                <CheckBox Name="CfgNoDiag" Content="Disable Diagnostic Data" Foreground="White" Margin="0,8"/>
                                <CheckBox Name="CfgNoLocation" Content="Disable Location Services" Foreground="White" Margin="0,8"/>
                                <CheckBox Name="CfgDefender" Content="Retain Windows Defender" Foreground="White" Margin="0,8"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Visuals">
                            <StackPanel>
                                <CheckBox Name="CfgAcrylic" Content="Enable Acrylic (Glass) Effects" Foreground="White" Margin="0,8"/>
                                <CheckBox Name="CfgNoStartSound" Content="Disable Startup Sound" Foreground="White" Margin="0,8"/>
                                <CheckBox Name="CfgFontSmooth" Content="Enable Font Smoothing" Foreground="White" Margin="0,8"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Advanced Filesystem (FSUTIL)" Foreground="#D4AF37" Grid.ColumnSpan="2">
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,10,0">
                                    <CheckBox Name="CfgFsNo83" Content="Disable 8.3 Name Creation" Foreground="White" Margin="0,5"/>
                                    <CheckBox Name="CfgFsStripSafe" Content="Strip 8.3 from Apps/Users (Safe)" Foreground="White" Margin="0,5"/>
                                    <CheckBox Name="CfgFsStripAll" Content="Strip 8.3 Global (RISKY: Windows folder)" Foreground="#FF4B4B" Margin="0,5"/>
                                </StackPanel>
                                <StackPanel>
                                    <CheckBox Name="CfgFsNoAccess" Content="Disable Last Access Update" Foreground="White" Margin="0,5"/>
                                    <DockPanel LastChildFill="True" Margin="0,5">
                                        <TextBlock Text="MFT Zone" Width="70" Foreground="Gray"/>
                                        <ComboBox Name="CfgFsMftZone" Background="#252526" Foreground="White" SelectedIndex="0">
                                            <ComboBoxItem Content="1 (Small)"/>
                                            <ComboBoxItem Content="2 (Medium)"/>
                                            <ComboBoxItem Content="3 (Large)"/>
                                            <ComboBoxItem Content="4 (Maximum)"/>
                                        </ComboBox>
                                    </DockPanel>
                                    <CheckBox Name="CfgFsLargeCache" Content="MemoryUsage: Large System Cache" Foreground="White" Margin="0,5"/>
                                </StackPanel>
                            </UniformGrid>
                        </GroupBox>
                    </UniformGrid>

                </StackPanel>
            </ScrollViewer>

            <!-- APPS PAGE -->
            <Grid Name="PageApps" Visibility="Collapsed">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <TextBlock Text="Applications" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                <ScrollViewer Grid.Row="1">
                    <ItemsControl Name="AppList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#2D2D30" BorderThickness="0,0,0,1" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" Grid.Column="1" Margin="15,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        <Button Name="SaveAppSelection" Content="Update" Grid.Column="2" Background="#2D2D30" Foreground="White" Padding="10,2"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- BUILD PAGE -->
            <Grid Name="PageBuild" Visibility="Collapsed">
                 <StackPanel MaxWidth="550" HorizontalAlignment="Left">
                    <TextBlock Text="Execute Build" FontSize="24" FontWeight="Bold" Margin="0,0,0,25"/>

                    <GroupBox Header="1. Deployment Destination">
                        <StackPanel>
                            <RadioButton Name="ModeIso" Content="Generate Standalone ISO (.iso)" IsChecked="True" Foreground="White" Margin="0,5"/>
                            <RadioButton Name="ModeUsb" Content="Flash Directly to USB Drive" Foreground="White" Margin="0,5"/>
                            
                            <!-- USB Selection (Visible when ModeUsb is checked) -->
                            <StackPanel Name="UsbSelectionArea" Visibility="Collapsed" Margin="25,10,0,0">
                                <TextBlock Text="Select USB Target Disk" Foreground="#888888" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <ComboBox Name="UsbDriveList" Background="#252526" Foreground="White" Height="35"/>
                                    <Button Name="RefreshUsb" Content="Refresh" Grid.Column="1" Width="80" Margin="10,0,0,0" Background="#333333" Foreground="White"/>
                                </Grid>
                                <TextBlock Text="WARNING: Selecting a USB will WIPE ALL DATA on that disk." Foreground="#FF4B4B" FontSize="11" Margin="0,10,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="2. Build Parameters">
                        <StackPanel>
                            <TextBlock Text="Source ISO Path" FontWeight="Bold" Margin="0,0,0,5"/>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox Name="SourcePath" Background="#252526" Foreground="White" Padding="10"/>
                                <Button Name="BrowseSource" Content="Browse" Grid.Column="1" Width="80" Margin="10,0,0,0" Background="#333333" Foreground="White"/>
                            </Grid>
                            
                            <CheckBox Name="SyncVentoy" Content="Generate Ventoy Post-Install Plugin" Foreground="White" Margin="0,10,0,0"/>
                        </StackPanel>
                    </GroupBox>
                    
                    <Border Background="#1E1E1E" Padding="20" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="Build Summary" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Name="SummaryText" Text="Ready to build GoldISO." Foreground="#888888" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Button Name="StartBuild" Content="START AUTOMATED BUILD" Height="60" Margin="0,30,0,0" Background="#D4AF37" Foreground="Black" FontWeight="Bold" FontSize="16"/>
                    <Button Name="TestInVM" Content="VERIFY IN SANDBOX (HYPER-V)" Height="40" Margin="0,15,0,0" Background="#181818" Foreground="#888888" BorderBrush="#444444"/>
                </StackPanel>
            </Grid>

            <!-- MAINTENANCE PAGE -->
            <Grid Name="PageMain" Visibility="Collapsed">
                <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                    <TextBlock Text="Project Maintenance" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    <GroupBox Header="Backup &amp; Export">
                        <StackPanel>
                            <TextBlock Text="Export your entire project (Manifests, Drivers, Wallpapers) into a portable package." Foreground="#888888" TextWrapping="Wrap" Margin="0,0,0,15"/>
                            <Button Name="ExportProject" Content="GENERATE PROJECT BACKUP (.goldiso)" Height="40" Background="#2D2D30" Foreground="White" BorderBrush="#D4AF37"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Import &amp; Migration">
                        <StackPanel>
                            <TextBlock Text="Restore a project from a previous backup or import external WIM/ISO samples." Foreground="#888888" TextWrapping="Wrap" Margin="0,0,0,15"/>
                            <Button Name="ImportProject" Content="IMPORT PROJECT PACKAGE" Height="40" Background="#2D2D30" Foreground="White" BorderBrush="#D4AF37" Margin="0,0,0,10"/>
                            <Button Name="ImportWIM" Content="IMPORT EXTERNAL WIM / INDEX" Height="40" Background="#2D2D30" Foreground="White" BorderBrush="#444444"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Settings Backup">
                        <StackPanel Orientation="Horizontal">
                            <Button Name="BackupConfig" Content="Backup Configs" Width="150" Height="35" Background="#2D2D30" Foreground="White" Margin="0,0,10,0"/>
                            <Button Name="RestoreConfig" Content="Restore Configs" Width="150" Height="35" Background="#2D2D30" Foreground="White"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </Grid>

            <!-- DEVELOPER PAGE -->
            <Grid Name="PageDev" Visibility="Collapsed">
                <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="Manifest Editor" FontWeight="Bold" Margin="0,0,0,15"/>
                    <Button Name="LoadManifest" Content="Build Manifest" Height="30" Margin="0,0,0,10" Background="#2D2D30" Foreground="White"/>
                    <Button Name="LoadBlacklist" Content="Bloat Blacklist" Height="30" Margin="0,0,0,20" Background="#2D2D30" Foreground="White"/>
                    <Button Name="SaveManifest" Content="Commit Changes" Height="40" Background="#D4AF37" Foreground="Black" FontWeight="Bold"/>
                </StackPanel>
                <TextBox Name="ManifestEditor" Grid.Column="1" AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas" Background="#0A0A0A" Foreground="#DCDCDC" Padding="10" VerticalScrollBarVisibility="Auto"/>
            </Grid>

            <!-- SERVICES PAGE (V3.1) -->
            <Grid Name="PageServices" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Services Editor" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="Configure Windows services and startup delays for the pre-boot environment." Foreground="#888888"/>
                </StackPanel>
                
                <DataGrid Name="ServiceGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" 
                          Background="#1E1E1E" Foreground="White" BorderThickness="1" BorderBrush="#2D2D30"
                          RowBackground="#1E1E1E" AlternatingRowBackground="#252526" GridLinesVisibility="None"
                          HeadersVisibility="Column" SelectionMode="Single" CanUserResizeRows="False">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#2D2D30"/>
                            <Setter Property="Foreground" Value="#D4AF37"/>
                            <Setter Property="Padding" Value="10,5"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#444444"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,5"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#3E3E42"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Service Name" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" ToolTipService.InitialShowDelay="500">
                                        <TextBlock.ToolTip>
                                            <ToolTip Background="#252526" Foreground="White" BorderBrush="#D4AF37">
                                                <StackPanel MaxWidth="300">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="0,0,0,5"/>
                                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTemplateColumn Header="Startup Type" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox SelectedValue="{Binding Startup, UpdateSourceTrigger=PropertyChanged}" 
                                              Background="#252526" Foreground="White">
                                        <ComboBoxItem Content="Automatic"/>
                                        <ComboBoxItem Content="Automatic (Delayed)"/>
                                        <ComboBoxItem Content="Manual"/>
                                        <ComboBoxItem Content="Disabled"/>
                                    </ComboBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Delay (Seconds)" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding DelayS, UpdateSourceTrigger=PropertyChanged}" 
                                             Background="#121212" Foreground="#D4AF37" 
                                             TextAlignment="Center" Padding="2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <Button Name="SaveServices" Grid.Row="2" Content="COMMIT SERVICE CHANGES" Height="45" Margin="0,20,0,0"
                        Background="#D4AF37" Foreground="Black" FontWeight="Bold"/>
            </Grid>

            <!-- DRIVERS PAGE (V3.1) -->
            <Grid Name="PageDrivers" Visibility="Collapsed">
                 <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Driver Store Professional" FontSize="24" FontWeight="Bold"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Manage pre-installed drivers and inject manufacturer packages." Foreground="#888888"/>
                        <Button Name="ScanDrivers" Content="SCAN SOURCE IMAGE" Grid.Column="1" Padding="15,5" Background="#333333" Foreground="White"/>
                    </Grid>
                </StackPanel>
                <DataGrid Name="DriverGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" Background="#1E1E1E" RowBackground="#1E1E1E" Foreground="White">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Remove" Binding="{Binding IsSelected}" Width="60"/>
                        <DataGridTextColumn Header="Published Name" Binding="{Binding PublishedName}" Width="110"/>
                        <DataGridTextColumn Header="Class" Binding="{Binding ClassName}" Width="100"/>
                        <DataGridTextColumn Header="Provider" Binding="{Binding ProviderName}" Width="120"/>
                        <DataGridTextColumn Header="Version" Binding="{Binding DriverVersion}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,20,0,0">
                    <Button Name="AddDriverFolder" Content="ADD DRIVER FOLDER" Width="180" Height="40" Background="#2D2D30" Foreground="White" Margin="0,0,10,0"/>
                    <Button Name="CommitDrivers" Content="QUEUE DRIVER CHANGES" Width="220" Height="40" Background="#D4AF37" Foreground="Black" FontWeight="Bold"/>
                </StackPanel>
            </Grid>

            <!-- DEBLOAT PAGE (V3.1) -->
            <Grid Name="PageDebloat" Visibility="Collapsed">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="AppX Debloater" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="Select provisioned packages to be purged during the build process." Foreground="#888888"/>
                </StackPanel>
                <DataGrid Name="DebloatGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" Background="#1E1E1E" Foreground="White">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Purge" Binding="{Binding IsSelected}" Width="60"/>
                        <DataGridTextColumn Header="Package Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Risk" Binding="{Binding RiskLevel}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,15,0,0">
                    <Button Name="DebloatSelectRecommended" Content="SELECT RECOMMENDED" Padding="15,8" Background="#333333" Foreground="White" Margin="0,0,10,0"/>
                    <Button Name="SaveDebloat" Content="QUEUE PURGE LIST" Padding="20,8" Background="#D4AF37" Foreground="Black" FontWeight="Bold"/>
                </StackPanel>
            </Grid>

            <!-- REGISTRY PAGE (V3.1) -->
            <Grid Name="PageRegistry" Visibility="Collapsed">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Offline Registry Editor" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="Define custom registry modifications to be applied to the target hives." Foreground="#888888"/>
                </StackPanel>
                <DataGrid Name="RegistryGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" Background="#1E1E1E" Foreground="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Hive" Binding="{Binding Hive}" Width="80"/>
                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*"/>
                        <DataGridTextColumn Header="Value" Binding="{Binding Name}" Width="120"/>
                        <DataGridTextColumn Header="Data" Binding="{Binding Data}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,15,0,0">
                    <Button Name="ImportRegFile" Content="IMPORT .REG FILE" Padding="15,8" Background="#2D2D30" Foreground="White" Margin="0,0,10,0"/>
                    <Button Name="ClearRegQueue" Content="CLEAR QUEUE" Padding="15,8" Background="#333333" Foreground="White" Margin="0,0,10,0"/>
                    <Button Name="SaveRegistry" Content="QUEUE TWEAKS" Padding="20,8" Background="#D4AF37" Foreground="Black" FontWeight="Bold"/>
                </StackPanel>
            </Grid>

        </Grid>

        <!-- Console -->
        <Border Grid.Row="1" Grid.Column="1" Height="200" Background="#0A0A0A" BorderThickness="0,1,0,0" BorderBrush="#2D2D30">
            <RichTextBox Name="ConsoleOutput" IsReadOnly="True" Background="Transparent" Foreground="#DCDCDC" FontFamily="Consolas" FontSize="11" BorderThickness="0" Padding="10" VerticalScrollBarVisibility="Auto"/>
        </Border>
    </Grid>
</Window>
