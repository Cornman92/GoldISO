# Normalize line endings to LF on check-in, use LF on checkout
* text=auto eol=lf

# PowerShell files — always LF
*.ps1  text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf

# XML / JSON / CMD — always LF
*.xml  text eol=lf
*.json text eol=lf
*.cmd  text eol=lf
*.bat  text eol=lf

# Markdown
*.md   text eol=lf

# Binaries — no conversion
*.iso  binary
*.wim  binary
*.msu  binary
*.cab  binary
*.msixbundle binary
*.exe  binary
*.dll  binary
*.inf  binary
*.cat  binary
