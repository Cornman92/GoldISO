{
  "$schema": "./Unattend/Profiles/_schema.json",
  "name": "GamerOS Gaming Profile",
  "description": "Maximum gaming performance with minimal bloat for desktop gaming rigs",
  "version": "1.0.0",
  "targetOS": "Windows 11 25H2",
  "author": "GoldISO Project",
  
  "variables": {
    "PRODUCT_KEY": "VK7JG-NPHTM-C97JM-9MPGT-3V66T",
    "IMAGE_INDEX": "1",
    "WINDOWS_DISK_ID": "2",
    "WINDOWS_PARTITION_ID": "3",
    "APPS_DISK_ID": "0",
    "MEDIA_DISK_ID": "1",
    "INPUT_LOCALE": "0409:00000409",
    "SYSTEM_LOCALE": "en-US",
    "UI_LANGUAGE": "en-US",
    "USER_LOCALE": "en-US",
    "UI_FALLBACK": "en-US",
    "NETWORK_LOCATION": "Home",
    "PROTECT_YOUR_PC": "3",
    "SKIP_USER_OOBE": "true",
    "SKIP_MACHINE_OOBE": "true",
    "DISABLE_INTERNET": "true",
    "INSTALL_RAMDISK": "true",
    "INSTALL_CHOCOLATEY": "true",
    "DNS_PRIMARY": "1.1.1.1",
    "DNS_SECONDARY": "8.8.8.8",
    "GPU_VENDOR": "NVIDIA",
    "GPU_MODEL": "RTX 3060 Ti"
  },
  
 "diskConfiguration": {
   "template": "MultiDisk-Gaming",
   "windowsDisk": {
     "diskId": 2,
     "type": "NVMe",
     "partitions": [
       { "type": "EFI", "size": 300, "format": "FAT32", "label": "System" },
       { "type": "MSR", "size": 16 },
       { "type": "Windows", "extend": true, "format": "NTFS", "label": "Windows", "letter": "C" },
       { "type": "Recovery", "size": 15360, "format": "NTFS", "label": "Recovery" }
     ],
     "postActions": [
       {
         "action": "shrink",
         "partition": "Windows",
         "shrinkByMB": 107520
       }
     ]
   },
   "secondaryDisks": [
     { "diskId": 0, "type": "SSD", "purpose": "Apps/Scratch", "wipeOnly": true },
     { "diskId": 1, "type": "HDD", "purpose": "Media/Storage", "wipeOnly": true }
   ]
 },
 
 "oobe": {
   "hideEULAPage": true,
   "hideOEMRegistrationScreen": true,
   "hideOnlineAccountScreens": true,
   "hideWirelessSetupInOOBE": true,
   "hideLocalAccountScreen": true,
   "hideOEMScreen": true,
   "networkLocation": "Home",
   "protectYourPC": 3,
   "skipUserOOBE": true,
   "skipMachineOOBE": true,
   "disableInternetConnection": true
 },
 
 "features": {
   "enable": [
     "Microsoft-Windows-Subsystem-Linux",
     "Microsoft-Hyper-V-All",
     "Containers-DisposableClientVM",
     "LegacyComponents",
     "NetFx3"
   ],
   "disable": [
     "Internet-Explorer-Optional-amd64",
     "Printing-PrintToPDFServices-Features",
     "Printing-XPSServices-Features",
     "PrintFaxesAndScanners",
     "Printing-PrintFaxesAndScanners-Features",
     "Print-PrintCore-Features",
     "Print-PrintWorkflowUserSvc",
     "ActiveDirectoryRightsManagementServicesClient",
     "ActiveDirectoryRightsManagementServicesClient-Features",
     "DataCenterBridging",
     "Internet Information Services Hostable Web Core",
     "Microsoft Print to PDF",
     "Print and Document Services",
     "Microsoft XPS Document Writer",
     "MultiPoint Connector",
     "SMB 1.0/CIFS File Sharing Support",
     "Windows TIFF IFilter",
     "Work Folders Client"
   ]
 },
 
 "gamingOptimizations": {
   "disableGameDVR": true,
   "disableNaglesAlgorithm": true,
   "optimizeNetBIOS": true,
   "disableSysMain": true,
   "highPerformancePowerPlan": true,
   "gpuPowerManagement": true,
   "excludeGamingDrivesFromIndexing": true,
   "disableDefragOnGamingDrives": true
 },
 
 "privacy": {
   "disableTelemetry": false,
   "disableCortana": true,
   "disableLocation": false,
   "disableCameraAccess": true,
   "disableMicrophoneAccess": true,
   "disableAdvertisingID": true,
   "disableFeedbackHub": true,
   "disableBackgroundApps": true,
   "disableWindowsTips": true,
   "disableWindowsRecall": true,
   "disableBingSearch": true,
   "blockTelemetryHosts": true
 },
 
 "security": {
   "disableSMBv1": true,
   "enableSMBv3": true,
   "enableWindowsFirewall": true,
   "configureDefender": true,
   "enableVBS": true,
   "enableCFG": true,
   "disableLM_NTLM": true,
   "disableBitLocker": true,
   "disableWindowsHello": true,
   "defenderExclusions": [
     "chrome.exe",
     "firefox.exe",
     "code.exe",
     "devenv.exe",
     "setup.exe",
     "*.tmp",
     "dotnet.exe",
     "node.exe",
     "git.exe"
   ]
 },
 
 "firstLogonCommands": {
   "enableNetwork": true,
   "installChocolatey": true,
   "installApps": true,
   "setGamingDNS": true,
   "setHighPerformance": true,
   "configurePrivacy": true,
   "installRAMDisk": true,
   "createRAMDisk": true,
   "redirectBrowserCache": true,
   "deployScripts": true,
   "deployPowerShellProfile": true,
   "installGPUDrivers": true,
   "installPeripherals": true,
   "installGitHubCLI": true,
   "deployPortableApps": true,
   "configureRemoteAccess": true,
   "restoreSettings": true
 },
 
 "scripts": {
   "winhancements": {
     "enabled": true,
     "configFile": "winhancements-config.json",
     "autoRun": true
   },
   "winutil": {
     "enabled": true,
     "configFile": "winutil-config.json",
     "autoRun": true
   },
   "customTweaks": {
     "systemTweaks": true,
     "userTweaks": true
   }
 },
 
 "debloat": {
   "removeApps": [
     "Microsoft.BingNews",
     "Microsoft.BingWeather",
     "Microsoft.SkypeApp",
     "Microsoft.Teams",
     "Microsoft.Office.OneNote",
     "Microsoft.MicrosoftSolitaireCollection",
     "Microsoft.MixedReality.Portal",
     "Microsoft.Microsoft3DViewer",
     "Microsoft.Print3D",
     "Microsoft.MicrosoftStickyNotes",
     "Microsoft.WindowsCamera",
     "Microsoft.WindowsMaps",
     "Microsoft.WindowsSoundRecorder",
     "Microsoft.ZuneVideo",
     "Microsoft.ZuneMusic",
     "Microsoft.People",
     "Microsoft.GetHelp",
     "Microsoft.GetStarted",
     "Microsoft.WindowsFeedbackHub",
     "Microsoft.XboxSpeechToTextOverlay"
   ],
   "preserveApps": [
     "Microsoft.XboxGameOverlay",
     "Microsoft.GamingApp",
     "Microsoft.XboxGamingOverlay",
     "Microsoft.DirectXDiagnosticTool",
     "Microsoft.WindowsTerminal",
     "Microsoft.GetHelp",
     "Clipchamp.Clipchamp",
     "Microsoft.MicrosoftOfficeHub"
   ]
 },
 
 "remoteAccess": {
   "enableRDP": true,
   "rdpSubnet": "100.64.0.0/10",
   "disableNLA": false,
   "createRemoteAccessShortcut": true
 },
 
 "drivers": {
   "injectFromUSB": true,
   "injectCategories": [
     "System devices",
     "Network adapters",
     "Storage controllers",
     "IDE ATA ATAPI controllers"
   ],
   "postInstallFromUSB": true,
   "postInstallCategories": [
     "Sound, video and game controllers",
     "Audio Processing Objects (APOs)",
     "Software components",
     "Extensions",
     "Monitors"
   ],
   "postInstallDrivers": [
     {
       "name": "NVIDIA GeForce RTX 3060 Ti",
       "version": "32.0.15.6094",
       "path": "Drivers\\Display adapters\\NVIDIA GeForce RTX 3060 Ti_32.0.15.6094"
     },
     {
       "name": "Logitech G403 HERO",
       "version": "1.1.77.5292",
       "path": "Drivers\\Universal Serial Bus controllers\\G403 HERO_1.1.77.5292"
     }
   ],
   "postInstallOptions": {
     "method": "pnputil-batch",
     "stageDriversPath": "C:\\Windows\\Setup\\Drivers\\PostInstall",
     "installDuringFirstLogon": true,
     "rebootAfterInstall": false
   }
 },
 
 "packages": {
   "injectFromUSB": true,
   "msix": [
     "Microsoft.DesktopAppInstaller_8wekyb3d8bbwe.msixbundle",
     "Microsoft.WindowsTerminal_1.24.10621.0_8wekyb3d8bbwe.msixbundle",
     "PowerShell-7.6.0.msixbundle"
   ],
   "appx": [
     "Microsoft.WindowsAppRuntime.1.8_8000.616.304.0_x64.appx",
     "Microsoft.UI.Xaml.2.8_8.2501.31001.0_x64.appx"
   ],
   "updates": [
     "windows11.0-kb5067931-x64-ndp481_495c5436de8d0ceb6b7a1982988f61ce0be71f38.msu",
     "windows11.0-kb5068516-x64_52337d6ab0d11b474dfafe1b14155d4a63ac2a8a.cab",
     "windows11.0-kb5043080-x64_953449672073f8fb99badb4cc6d5d7849b9c83e8.msu",
     "windows11.0-kb5085516-x64_52aef89bc1afc5e67eec927556ec6926122936ad.msu",
     "windows11.0-kb5074828-x64-ndp481_88bbe39d8dc9e306cd2d5faa817c8656e6d798d7.msu",
     "windows11.0-kb5079391-x64_0a0129ebe88fdd66e19ac7d40d9cddd0b18c3332.msu",
     "windows11.0-kb5083482-x64_3fdfdf01ddc1db954190523120dd75e494404770.cab",
     "windows11.0-kb5066128-x64-ndp481_e2239075b7e05662cbbe1b4acfe9e57e40a2b9c0.msu",
     "updateplatform.amd64fre_a94fdbcbdd69a5cab6032175a4be11f9a52db59f.exe"
   ]
 },
 
 "portableApps": {
   "deployFromUSB": true,
   "destination": "C:\\Apps\\Portable",
   "apps": [
     "7-ZipPortable",
     "EverythingPortable",
     "FreeCommanderPortable",
     "Explorer++Portable",
     "FileVoyagerPortable",
     "AutorunsPortable",
     "BleachBitPortable",
     "ClamWinPortable",
     "EmsisoftEmergencyKitPortable",
     "InnoUnpackerPortable",
     "PortableApps.com",
     "JkDefragPortable",
     "CPU-ZPortable",
     "GPU-ZPortable",
     "HWiNFOPortable",
     "HWMonitorPortable",
     "FileZillaPortable",
     "ConsolePortable",
     "CopyQPortable",
     "DM2Portable",
     "FreeFileSyncPortable",
     "grepWinPortable",
     "DittoPortable",
     "DuplicateFilesFinderPortable",
     "fcpyPortable",
     "DaphnePortable",
     "CommonFiles"
   ]
 },
 
 "ramdisk": {
   "enabled": true,
   "sizeMB": 8192,
   "driveLetter": "R",
   "persist": true,
   "redirectBrowserCache": true
 },
 
 "diskOptimization": {
   "shrinkWindowsGB": 105,
   "recoveryPartitionGB": 15,
   "overprovisioningGB": 90,
   "runDuringSpecialize": true
 },
 
 "directories": {
   "createOnC": [
     "Dev",
     "Gaming",
     "Utils",
     "Media",
     "Remote",
     "Scripts"
   ]
 },
 
 "settingsMigration": {
   "enabled": true,
   "scriptPath": "C:\\SettingsMigration\\restore-settings.ps1"
 },
 
 "logging": {
   "enabled": true,
   "logPath": "C:\\ProgramData\\Winhance\\Unattend\\Logs",
   "logFiles": [
     "disk-config.log",
     "driver-injection.log",
     "package-injection.log",
     "update-injection.log",
     "tweaks-system.log",
     "tweaks-user.log",
     "ramdisk-install.log",
     "ramdisk-create.log",
     "browser-cache.log",
     "usb-apps-install.log",
     "winutil.log",
     "remote-access.log"
   ]
 }
}