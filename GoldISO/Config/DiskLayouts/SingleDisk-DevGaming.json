{
  "name": "SingleDisk-DevGaming",
  "description": "Single disk with Windows C:, includes Dev and Gaming folders (not partitions)",
  "targetHardware": "Z390-P with 1TB+ NVMe/SATA SSD",
  "totalDiskSize": "~901GB",
  "variables": {
    "DISK_ID": "0",
    "EFI_SIZE": "300",
    "MSR_SIZE": "16",
    "WINDOWS_PARTITION_SIZE": "337920",
    "RECOVERY_SIZE": "10240",
    "WINDOWS_LETTER": "C",
    "CREATE_DEV_FOLDER": "true",
    "CREATE_GAMING_FOLDER": "true"
  },
  "partitions": [
    {"order": 1, "type": "EFI", "size": "300", "format": "FAT32", "label": "System"},
    {"order": 2, "type": "MSR", "size": "16"},
    {"order": 3, "type": "Primary", "size": "337920", "format": "NTFS", "label": "Windows", "letter": "C"},
    {"order": 4, "type": "Primary", "size": "10240", "format": "NTFS", "label": "Recovery"}
  ],
  "folders": [
    {"path": "C:\\Dev", "description": "Development projects and apps"},
    {"path": "C:\\Gaming", "description": "Games and game launchers (Steam, Battle.net, Epic, etc.)"}
  ]
}
