{
  "_version": "1.0",
  "_lastUpdated": "2026-04-08",
  "description": "Driver queue configuration for GoldISO build. Mark drivers for removal or injection.",
  "remove": [],
  "inject": [
    {
      "path": "Network adapters",
      "description": "Intel/R Realtek network drivers",
      "enabled": true
    },
    {
      "path": "Storage controllers",
      "description": "Intel RST and Samsung NVMe drivers",
      "enabled": true
    },
    {
      "path": "System devices",
      "description": "Intel MEI and system device drivers",
      "enabled": true
    },
    {
      "path": "Sound, video and game controllers",
      "description": "Realtek audio and NVIDIA HD audio",
      "enabled": true
    },
    {
      "path": "Software components",
      "description": "Realtek audio components and Intel utilities",
      "enabled": true
    }
  ],
  "postInstall": [
    {
      "description": "NVIDIA GeForce RTX 3060 Ti",
      "infPath": "Display adapters\\NVIDIA GeForce RTX 3060 Ti_32.0.15.6094\\nvmd.inf",
      "method": "pnputil",
      "note": "Installed post-boot via FirstLogonCommands"
    },
    {
      "description": "Logitech G403 HERO",
      "infPath": "Universal Serial Bus controllers\\G403 HERO_1.1.77.5292\\logi_lamparray_usb.inf",
      "method": "pnputil",
      "note": "Installed post-boot via FirstLogonCommands"
    }
  ]
}
